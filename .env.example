PORT=3000
SESSION_SECRET=change-this-to-a-long-random-string-in-production

# Set this (to any non-empty value) only if you're deploying behind a
# reverse proxy / load balancer (Render, Railway, Fly.io, nginx, etc).
# It makes the app trust the X-Forwarded-For header so the login
# rate limiter sees the real visitor IP instead of the proxy's IP.
# Leave unset for local/direct deployments - trusting it when there's no
# proxy in front of you lets clients spoof their own IP.
# TRUST_PROXY=1

# ---- Optional: email alerts on repeated login lockouts ----
# If this raffle handles real money, you probably want to know when someone
# is hammering the admin login rather than finding out by accident. Leave
# all of these unset to disable email alerts (lockouts still get logged to
# the console either way). Any SMTP provider works - e.g. Gmail app
# passwords, SendGrid, Mailgun, Postmark, AWS SES.
# ALERT_EMAIL_TO=you@example.com
# ALERT_EMAIL_FROM=alerts@yourdomain.com
# SMTP_HOST=smtp.yourprovider.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-username
# SMTP_PASS=your-smtp-password
